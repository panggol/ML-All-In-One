# ML All In One - Environment Variables
# Copy this file to .env and fill in the values

# JWT Secret Key (required)
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
MLKIT_JWT_SECRET=your-secret-key-here

# Alternative JWT Secret Key name (fallback if MLKIT_JWT_SECRET is not set)
# JWT_SECRET_KEY=your-secret-key-here

# Database URL (default: SQLite in ./data/)
DATABASE_URL=sqlite:///./data/ml_all_in_one.db

# CORS Allowed Origins (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Max file upload size in bytes (default: 500MB)
MAX_FILE_SIZE_BYTES=524288000

# Models directory (default: ./models)
MODELS_DIR=./models

# Upload directory (default: ./uploads)
UPLOAD_DIR=./uploads

# Default admin credentials (change in production!)
MLKIT_ADMIN_USERNAME=admin
MLKIT_ADMIN_PASSWORD=admin123
